{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "flutter",
      "command": "flutter",
      "args": [
        "pub",
        "run",
        "build_runner",
        "build",
        "--delete-conflicting-outputs"
      ],
      "problemMatcher": ["$dart-build_runner"],
      "group": "build",
      "label": "flutter: build runner",
      "detail": ""
    },
    {
      "type": "shell",
      "command": "dart",
      "args": [
        "run",
        "easy_localization:generate",
        "-S",
        "assets/lang",
        "-O",
        "lib/core/resources/gen",
        "-o",
        "locale_keys.g.dart",
        "-f",
        "keys"
      ],
      "group": "build",
      "label": "flutter: generate localization",
      "detail": ""
    }
  ]
}
